{
  "name": "go-champs-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test:coverage",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "collectCoverageFrom": [
      "src/core/**/*.{ts,tsx}",
      "src/data/**/*.{ts,tsx}",
      "src/domain/**/*.{ts,tsx}",
      "!src/data/dto/**",
      "!src/domain/repositories/**",
      "!src/core/http/HttpClient.ts",
      "!src/**/__tests__/**",
      "!src/test/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@react-navigation/stack": "^7.1.1",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.7",
    "expo-constants": "~18.0.10",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^18.3.0",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@babel/helpers": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@tootallnate/once": "^2.0.1",
    "@xmldom/xmldom": "^0.8.13",
    "brace-expansion": "^2.0.3",
    "form-data": "^4.0.5",
    "@expo/cli": {
      "glob": "^10.5.0"
    },
    "@expo/config": {
      "glob": "^10.5.0"
    },
    "@expo/config-plugins": {
      "glob": "^10.5.0"
    },
    "@expo/devcert": {
      "glob": "^10.5.0"
    },
    "@expo/fingerprint": {
      "glob": "^10.5.0"
    },
    "@expo/metro-config": {
      "glob": "^10.5.0"
    },
    "expo-modules-autolinking": {
      "glob": "^10.5.0"
    },
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.24",
    "node-forge": "^1.4.0",
    "picomatch": "^4.0.3",
    "postcss": "^8.5.15",
    "react-server-dom-webpack": "19.1.7",
    "sucrase": {
      "glob": "^10.5.0"
    },
    "tar": "^7.5.10",
    "test-exclude": {
      "minimatch": "^3.1.3"
    },
    "undici": "^6.24.0",
    "uuid": "^11.1.1",
    "ws": "^8.20.1",
    "yaml": "^2.8.3"
  },
  "private": true
}
